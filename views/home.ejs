<% layout("/layouts/boilerplate") %>

<section class="container py-5 text-center my-5">
    <h1 class="display-2 fw-bold">
        Invest Smarter.
    </h1>

    <p class="lead text-muted mt-3">
        Track portfolios, monitor stocks, and make informed investment decisions.
    </p>

    <div class="mt-4">
        <a href="/register" class="btn btn-primary btn-lg me-2">
            Get Started
        </a>

        <a href="/about" class="btn btn-outline-secondary btn-lg">
            Learn More
        </a>
    </div>

    <div class="mt-5">
        <img src="/images/dashboard.png" class="img-fluid rounded shadow" alt="Dashboard Preview">
    </div>
</section>
<section class="container py-5">
    <div class="row text-center">

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-briefcase-fill display-4 text-primary"></i>
                    <h4>Portfolio Tracking</h4>
                    <p>Track all your investments in one place.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-eye-fill display-4 text-primary"></i>
                    <h4>Watchlist</h4>
                    <p>Keep an eye on stocks before investing.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <i class="bi bi-graph-up-arrow display-4 text-primary"></i>
                    <h4>Analytics</h4>
                    <p>Visualize your portfolio using charts.</p>
                </div>
            </div>
        </div>

    </div>
</section>
<section class="bg-light py-5">
    <div class="container">
        <div class="row text-center">

            <div class="col-md-4">
                <h2>10K+</h2>
                <p>Investors</p>
            </div>

            <div class="col-md-4">
                <h2>500+</h2>
                <p>Stocks Tracked</p>
            </div>

            <div class="col-md-4">
                <h2>99.9%</h2>
                <p>Uptime</p>
            </div>

        </div>
    </div>
</section>