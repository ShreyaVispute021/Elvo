<% layout("/layouts/boilerplate") %>

<section class="container hero-section text-center my-5">

    <span class="badge bg-primary-subtle text-primary px-3 py-2 mb-3">
        Smart Investing Platform
    </span>

    <h1 class="display-2 fw-bold">
        Build Wealth with
        <span class="text-primary">
            Confidence.
        </span>
    </h1>

    <p class="lead text-muted mt-3 mx-auto" style="max-width:700px;">
        Analyze stocks, manage portfolios, and practice investing through paper trading.
    </p>

    <div class="mt-4">
        <a href="/register" class="btn btn-primary btn-lg me-2">
            Get Started
        </a>

        <a href="/about" class="btn btn-outline-dark btn-lg">
            Learn More
        </a>
    </div>

</section>
<section class="container py-5">
    <div class="row text-center">

        <div class="col-md-4">
            <div class="card shadow feature-card h-100">
                <div class="card-body">
                    <i class="bi bi-briefcase-fill display-4 text-primary mb-3"></i>
                    <h4>Portfolio Tracking</h4>
                    <p>Track all your investments in one place.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow feature-card h-100">
                <div class="card-body">
                    <i class="bi bi-eye-fill display-4 text-primary mb-3"></i>
                    <h4>Watchlist</h4>
                    <p>Keep an eye on stocks before investing.</p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow feature-card h-100">
                <div class="card-body">
                    <i class="bi bi-graph-up-arrow display-4 text-primary mb-3"></i>
                    <h4>Analytics</h4>
                    <p>Visualize your portfolio using charts.</p>
                </div>
            </div>
        </div>

    </div>
</section>
<section class="bg-light py-5">
    <div class="container">
        <div class="row text-center">

            <div class="col-md-4">
                <h2>10K+</h2>
                <p>Investors</p>
            </div>

            <div class="col-md-4">
                <h2>500+</h2>
                <p>Stocks Tracked</p>
            </div>

            <div class="col-md-4">
                <h2>99.9%</h2>
                <p>Uptime</p>
            </div>

        </div>
    </div>
</section>